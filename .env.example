DATABASE_URL=postgresql://user:password@localhost:5432/bddigital
PORT=8080
NODE_ENV=production
ADMIN_USERNAME=your-admin-email@example.com
# Generate with: node -e "const b=require('bcryptjs');console.log(b.hashSync('your-password',12))"
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here
ADMIN_SECRET=your-super-secret-key-here
# BASE_PATH is only needed for dev server path prefix; defaults to "/"
BASE_PATH=/
